# Database (Neon PostgreSQL)
DATABASE_URL=postgresql+asyncpg://neondb_owner:your-password@your-project.us-west-2.aws.neon.tech/neondb?sslmode=require
POSTGRES_HOST=your-project.us-west-2.aws.neon.tech
POSTGRES_PORT=5432
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=your-password
POSTGRES_DB=neondb

# JWT Authentication (REQUIRED - generate a secure random key)
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# OpenAI API
OPENAI_API_KEY=your-openai-api-key

# Resend Email (https://resend.com - 3,000 emails/month free)
RESEND_API_KEY=re_your_api_key
EMAIL_FROM=onboarding@resend.dev

# Google OAuth (reused by Google sign-in AND Google Calendar integration)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs to whitelist in Google Cloud Console:
#   <your-frontend-origin>/auth/google/callback                       (sign-in)
#   <your-frontend-origin>/settings/integrations/google-calendar/callback (calendar)
# For Link Creative production that's:
#   https://crm-linkcreative-production.up.railway.app/auth/google/callback
#   https://crm-linkcreative-production.up.railway.app/settings/integrations/google-calendar/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Seed Data (creates admin account with sample data on startup)
# admin@admin.com / admin123 - Admin account with sample CRM data and default tenant
SEED_ON_STARTUP=true

# Application
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
DEBUG=true
