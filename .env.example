# Database (Neon PostgreSQL)
# Use the `-pooler` hostname so Neon's PgBouncer pools connections and the
# compute doesn't wake on every short-lived session. Example host:
#   ep-xxxx-pooler.c-2.us-east-2.aws.neon.tech
DATABASE_URL=postgresql+asyncpg://neondb_owner:your-password@your-project-pooler.us-west-2.aws.neon.tech/neondb?sslmode=require
POSTGRES_HOST=your-project-pooler.us-west-2.aws.neon.tech
POSTGRES_PORT=5432
POSTGRES_USER=neondb_owner
POSTGRES_PASSWORD=your-password
POSTGRES_DB=neondb

# JWT Authentication (REQUIRED - generate a secure random key: openssl rand -hex 32)
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=480

# Email sender display name (no transactional provider — outbound via Gmail)
EMAIL_FROM=no-reply@example.com

# Google OAuth (reused by Google sign-in AND Google Calendar integration)
# Create credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URIs to whitelist in Google Cloud Console:
#   <your-frontend-origin>/auth/google/callback                       (sign-in)
#   <your-frontend-origin>/settings/integrations/google-calendar/callback (calendar)
#   <your-frontend-origin>/settings/integrations/gmail/callback           (Gmail)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe payments
# Prefer a restricted API key (rk_test_... / rk_live_...) scoped to the CRM
# backend's required Stripe resources instead of a full secret key (sk_...).
STRIPE_SECRET_KEY=rk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_API_VERSION=2026-04-22.dahlia
# Optional: not required by the current frontend because Checkout is created
# server-side and the frontend does not load Stripe.js.
STRIPE_PUBLISHABLE_KEY=

# Cloudflare R2 object storage (for file attachments)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=

# Frontend origin — used to build Stripe Checkout redirect URLs, e-sign links,
# notification deep links, and Gmail OAuth redirect URIs. No trailing slash.
FRONTEND_BASE_URL=https://your-app.up.railway.app

# Meta (Facebook/Instagram) Lead Ads integration
# META_WEBHOOK_VERIFY_TOKEN is required when META_APP_SECRET is set.
# Set it to a random secret string and register the same value in the
# Meta developer dashboard as the webhook verify token.
META_ACCESS_TOKEN=
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=

# Mailchimp audience sync (optional)
MAILCHIMP_API_KEY=
MAILCHIMP_DEFAULT_AUDIENCE_ID=

# Comma-separated list of admin email addresses (for admin-level access grants)
ADMIN_EMAILS=

# Currency for CRM billing (ISO 4217, e.g. USD, EUR)
CRM_BASE_CURRENCY=USD

# Application
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]
DEBUG=false

# DEV-ONLY: seed the database with a demo admin account on startup.
# NEVER set to true in production — startup will refuse to boot if
# SEED_ON_STARTUP=true and DEBUG=false.
SEED_ON_STARTUP=false
